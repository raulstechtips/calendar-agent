AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_TRUST_HOST=true

# Backend URL — browser-facing (baked into client bundle at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000

