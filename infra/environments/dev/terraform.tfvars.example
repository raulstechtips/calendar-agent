# Dev environment variables
# Copy this file to terraform.tfvars and fill in values:
#   cp terraform.tfvars.example terraform.tfvars

project_name    = "calendaragent"
environment     = "dev"
location        = "eastus"
subscription_id = "00000000-0000-0000-0000-000000000000" # Your Azure subscription ID

# Developer access — grants data-plane RBAC on AI services for local development.
# Without this, `az login` + DefaultAzureCredential can manage resources (Owner/Contributor)
# but CANNOT call the service APIs (e.g. OpenAI completions, Search queries).
# Local auth (API keys) is disabled on all services, so Entra ID RBAC is the only auth path.
# Find your object ID: az ad signed-in-user show --query id -o tsv
developer_object_id = "00000000-0000-0000-0000-000000000000"

# Network — deployer IP allowlist for service firewalls
# Find your IP: curl -s ifconfig.me
deployer_ip_cidrs = ["203.0.113.1/32"]

# App secrets (set via TF_VAR_ env vars or terraform.tfvars — NEVER commit real values)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
fernet_key = "CHANGE_ME"
# From Google Cloud Console → APIs & Services → Credentials
google_client_id     = "CHANGE_ME"
google_client_secret = "CHANGE_ME"
# Generate: openssl rand -base64 32
auth_secret = "CHANGE_ME"
# Generate: openssl rand -hex 16
canary_token = "CHANGE_ME"

# GitHub Actions OIDC — used to create the federated credential for CI/CD
github_repo_name = "myorg/calendar-agent" # org/repo format
